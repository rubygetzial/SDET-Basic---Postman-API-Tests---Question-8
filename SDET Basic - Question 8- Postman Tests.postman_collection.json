          "name": "Positive POST - Create new object with valid data",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test 1: Verify Status Code is 201 Created",
                  "pm.test('Status code is 201 Created', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "// Test 2: Verify response has id property",
                  "pm.test('Response contains auto-generated id', function() {",
                  "    pm.expect(pm.response.json()).to.have.property('id');",
                  "});",
                  "",
                  "// Test 3: Verify response contains posted data",
                  "pm.test('Response contains correct name and data', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.name).to.equal('Apple MacBook Pro 16');",
                  "    pm.expect(jsonData.data.year).to.equal(2023);",
                  "});",
                  "",
                  "// Test 4: Save ID for future requests",
                  "pm.environment.set('created_object_id', pm.response.json().id);",
                  "",
                  "// Test 5: Verify timestamp exists",
                  "pm.test('Response includes timestamp', function() {",
                  "    pm.expect(pm.response.json()).to.have.property('createdAt');",
                  "});"
                ],
                "type": "text/javascript"
