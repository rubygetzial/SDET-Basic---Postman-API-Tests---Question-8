      "name": "GET API",
      "item": [
        {
          "name": "Positive GET - Retrieve existing object (ID: 5)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test 1: Verify Status Code is 200 OK",
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Test 2: Verify response has correct structure",
                  "pm.test('Response has id, name, and data properties', function() {",
                  "    pm.expect(pm.response.json()).to.have.property('id');",
                  "    pm.expect(pm.response.json()).to.have.property('name');",
                  "});",
                  "",
                  "// Test 3: Verify id matches request",
                  "pm.test('ID in response matches requested ID (5)', function() {",
                  "    pm.expect(pm.response.json().id).to.equal('5');",
                  "});",
                  "",
                  "// Test 4: Verify response time",
                  "pm.test('Response time is less than 1000ms', function() {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
